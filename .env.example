# ───────────────────────────────────────────────────────────
# DATABASE & GRAPH CONFIGURATION
# ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/crushed_studios
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ───────────────────────────────────────────────────────────
# REDIS & CACHE
# ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────
# EXTERNAL AI PROVIDER API KEYS
# ───────────────────────────────────────────────────────────
FAL_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=

# ───────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY
# ───────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ───────────────────────────────────────────────────────────
# STRIPE PAYMENTS
# ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=

# ───────────────────────────────────────────────────────────
# DEPLOYMENT & HOSTING STRATEGY
# ───────────────────────────────────────────────────────────
PROVIDER_MODE=serverless
NODE_ENV=development
