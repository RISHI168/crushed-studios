{
  "name": "crushed-studios",
  "version": "0.6.0",
  "description": "Crushed Studios - AI Video Generation Platform (Turborepo Monorepo)",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "workspaces": {
    "packages": [
      "packages/@cs/tokens",
      "packages/@cs/constants",
      "packages/@cs/types",
      "packages/@cs/utils",
      "packages/@cs/db",
      "packages/@cs/ai"
    ]
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "clean": "turbo clean && rm -rf node_modules",
    "install": "pnpm install"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
