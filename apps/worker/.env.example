# Worker Configuration
NODE_ENV=development
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/crushed_studios

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.9
MAX_BATCH_SIZE=4

# Model Configuration
MODEL_CACHE_DIR=/models
MODEL_DOWNLOAD_TIMEOUT=3600

# AI Services
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
REPLICATE_API_KEY=...

# Monitoring
SENTRY_DSN=...
