{
  "name": "@cs/tokens",
  "version": "0.6.0",
  "description": "Design system tokens - colors, fonts, gradients",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./colors": {
      "import": "./dist/colors.js",
      "types": "./dist/colors.d.ts"
    },
    "./fonts": {
      "import": "./dist/fonts.js",
      "types": "./dist/fonts.d.ts"
    },
    "./gradients": {
      "import": "./dist/gradients.js",
      "types": "./dist/gradients.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.5.2",
    "vitest": "^1.0.0"
  }
}
